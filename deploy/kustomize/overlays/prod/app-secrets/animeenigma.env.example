# Copy to animeenigma.env (git-ignored) and fill in real values.
# Strong secrets: openssl rand -hex 32
jwt-secret=CHANGE_ME
stream-token-secret=CHANGE_ME
db-password=CHANGE_ME
redis-password=
minio-access-key=CHANGE_ME
minio-secret-key=CHANGE_ME
clickhouse-user=analytics
clickhouse-password=CHANGE_ME
meili-master-key=CHANGE_ME
# External S3 backend for the storage service (optional — empty = MinIO-only)
s3-endpoint=
s3-access-key=
s3-secret-key=
# fanfic engine — REQUIRED (pod refuses to boot without it)
fanfic-groq-api-key=CHANGE_ME
# Telegram deep-link login — must match the bot's setWebhook secret_token.
# Empty = the /api/auth/telegram/webhook endpoint rejects every update.
telegram-webhook-secret=
# optional: absent/empty = feature degrades gracefully
analytics-ip-salt=
jackett-api-key=
job-capability-secret=
stealth-proxies=
stealth-warp-proxy-url=
