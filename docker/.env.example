# AnimeEnigma Production Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# =============================================================================
# Database
# =============================================================================
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# =============================================================================
# Redis
# =============================================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# =============================================================================
# MinIO (Video Storage)
# =============================================================================
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=animeenigma

# =============================================================================
# Environment
# =============================================================================
# Set to "production" to prevent DEV_MODE from being accidentally enabled
ENVIRONMENT=production

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS
STREAM_TOKEN_SECRET=CHANGE_ME_STREAM_SECRET_AT_LEAST_32_CHARS

# =============================================================================
# External APIs (Optional)
# =============================================================================
SHIKIMORI_USER_AGENT=AnimeEnigma/1.0 (your@email.com)
KODIK_API_KEY=
ANIBOOM_BASE_URL=
# Jimaku.cc API key for Japanese subtitles (https://jimaku.cc)
JIMAKU_API_KEY=
# AnimeLib JWT token for RU video sources
ANIMELIB_TOKEN=
# Hanime.tv credentials for 18+ content
HANIME_EMAIL=
HANIME_PASSWORD=

# =============================================================================
# Telegram Login Widget (Optional)
# =============================================================================
# Create bot via @BotFather, get token, run /setdomain to set your site domain
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# =============================================================================
# Monitoring & Admin (Optional)
# =============================================================================
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PGADMIN_EMAIL=admin@animeenigma.ru
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# =============================================================================
# Database Backup (S3)
# =============================================================================
S3_ENDPOINT=s3.firstvds.ru
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_BUCKET=animeenigma
S3_REGION=default
BACKUP_RETENTION_DAYS=14
TELEGRAM_BACKUP_CHAT_ID=
# Alerts bot for player error reports (separate from login bot)
TELEGRAM_ALERTS_BOT_TOKEN=
# Chat ID to receive player error reports from users
TELEGRAM_ADMIN_CHAT_ID=
# Telegram channel username for news feed (without @)
TELEGRAM_NEWS_CHANNEL=animeenigmanews

# =============================================================================
# Phase 18 — Gogoanime/Anitaku scraper provider
# =============================================================================
# Optional override for the Anitaku mirror. Defaults to https://anitaku.to.
# Gogoanime has historically rotated mirrors; if anitaku.to becomes
# unreachable, set this to the alive alternative (e.g. https://anitaku.io).
# SCRAPER_GOGOANIME_BASE_URL=https://anitaku.to

# =============================================================================
# Phase 19 — AnimeKai scraper provider (gated, escape-hatch)
# =============================================================================
# Default: OFF in production. AnimeKai shipped in Phase 19 as a flag-only
# stub because the in-house MegaUp token generator did not converge during
# R&D (AnimeKai officially announced shutdown 2026-05-10). The provider's
# Go methods return ErrProviderDown immediately, the sidecar /animekai-token
# route returns HTTP 501, and the orchestrator falls back to AnimePahe →
# Gogoanime without users seeing the third option.
#
# To enable (R&D / staging only — does NOT actually serve streams until
# SCRAPER-KAI-01..04 ship in v3.1):
#   SCRAPER_ANIMEKAI_ENABLED=true
# SCRAPER_ANIMEKAI_ENABLED=false
#
# Mirror override — defaults to https://anikai.to. animekai.to 301s here;
# both work. Override only if anikai.to becomes unreachable.
# SCRAPER_ANIMEKAI_BASE_URL=https://anikai.to

# =============================================================================
# workstream raw-jp / Phase 01 — AllAnime raw-JP provider
# =============================================================================
# AllAnime exposes a GraphQL persisted-query API serving original Japanese
# audio HLS streams. The persisted-query SHA256 hashes occasionally rotate
# (~every few months); when AllAnime breaks the existing values, refresh
# from a browser network capture or upstream reference (pystardust/ani-cli,
# justfoolingaround/animdl). Empty values fall back to known-good defaults
# baked into the parser package.
#
# Ordered fallback domain list. The parser caches the first responsive
# domain in memory for the process lifetime.
# ALLANIME_DOMAINS=allanime.day,allmanga.to,allanime.to
#
# Persisted-query SHA256 hashes. Empty = use parser-baked defaults.
# ALLANIME_QUERY_SEARCH_SHA=
# ALLANIME_QUERY_EPISODES_SHA=
# ALLANIME_QUERY_SOURCES_SHA=
#
# Per-request HTTP timeout. Default 10s.
# ALLANIME_HTTP_TIMEOUT=10s
#
# Headers expected by AllAnime's WAF.
# ALLANIME_REFERER=https://allmanga.to/
# ALLANIME_USER_AGENT=AnimeEnigma/1.0
