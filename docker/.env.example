# AnimeEnigma Production Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# =============================================================================
# Database
# =============================================================================
# These three are now the SINGLE source of truth: docker-compose passes the
# same DB_USER / DB_PASSWORD / DB_NAME to the postgres server AND to every
# service. Defaults (postgres / postgres / animeenigma) keep `make dev` and an
# un-tuned box working. To harden a live box you must ALSO re-key the existing
# postgres role — changing DB_PASSWORD alone does not touch an initialized
# volume. See docs/runbooks/secret-rotation.md.
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=animeenigma

# =============================================================================
# Redis
# =============================================================================
# NOTE: enabling Redis auth also requires adding `--requirepass` to the redis
# service `command:` in docker-compose.yml — setting this var alone only
# configures clients. See the runbook.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# =============================================================================
# MinIO (Video Storage)
# =============================================================================
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are the MinIO server root credentials
# that all internal services share (compose now reads these everywhere instead
# of the old hardcoded minioadmin/minioadmin). MinIO re-reads these from env on
# every restart, so rotating them is just: set strong values here + restart
# minio and its consumers. Defaults keep minioadmin/minioadmin.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=animeenigma

# =============================================================================
# Meilisearch
# =============================================================================
MEILI_MASTER_KEY=CHANGE_ME_MEILI_MASTER_KEY
MEILI_ENV=production

# =============================================================================
# Environment
# =============================================================================
# Set to "production" to prevent DEV_MODE from being accidentally enabled
ENVIRONMENT=production

# =============================================================================
# Security
# =============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS
STREAM_TOKEN_SECRET=CHANGE_ME_STREAM_SECRET_AT_LEAST_32_CHARS

# Mark the refresh_token / access_token cookies Secure. Set to true for ANY
# HTTPS deployment; leave false only for local http://localhost dev (Secure
# cookies are not stored by browsers over plain HTTP).
COOKIE_SECURE=false

# =============================================================================
# External APIs (Optional)
# =============================================================================
SHIKIMORI_USER_AGENT=AnimeEnigma/1.0 (your@email.com)
KODIK_API_KEY=
ANIBOOM_BASE_URL=
# Jimaku.cc API key for Japanese subtitles (https://jimaku.cc)
JIMAKU_API_KEY=
# AnimeLib JWT token for RU video sources
ANIMELIB_TOKEN=
# Hanime.tv credentials for 18+ content
HANIME_EMAIL=
HANIME_PASSWORD=

# =============================================================================
# Telegram Login Widget (Optional)
# =============================================================================
# Create bot via @BotFather, get token, run /setdomain to set your site domain
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=

# =============================================================================
# Monitoring & Admin (Optional)
# =============================================================================
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PGADMIN_EMAIL=admin@animeenigma.org
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# =============================================================================
# Database Backup (S3)
# =============================================================================
S3_ENDPOINT=s3.firstvds.ru
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_BUCKET=animeenigma
S3_REGION=default
# The streaming service's HLS proxy reuses S3_ENDPOINT/S3_ACCESS_KEY/
# S3_SECRET_KEY above to presign upstream GETs against this SAME external S3
# host for library episodes that live there instead of local MinIO — but
# NOT S3_BUCKET, which is the DB-backups bucket. S3_LIBRARY_BUCKET is the
# separate bucket library episodes are stored in (default "raw-library",
# matches local MinIO's bucket name). Leaving S3_ENDPOINT empty (the
# compose default) disables this second backend entirely; the proxy falls
# back to MinIO-only presigning.
# S3_LIBRARY_BUCKET=raw-library
BACKUP_RETENTION_DAYS=14
TELEGRAM_BACKUP_CHAT_ID=
# Alerts bot for player error reports (separate from login bot)
TELEGRAM_ALERTS_BOT_TOKEN=
# Chat ID to receive player error reports from users
TELEGRAM_ADMIN_CHAT_ID=
# Telegram channel username for news feed (without @)
TELEGRAM_NEWS_CHANNEL=animeenigmanews

# =============================================================================
# Phase 18 — Gogoanime/Anitaku scraper provider
# =============================================================================
# Optional override for the Anitaku mirror. Defaults to https://anitaku.to.
# Gogoanime has historically rotated mirrors; if anitaku.to becomes
# unreachable, set this to the alive alternative (e.g. https://anitaku.io).
# SCRAPER_GOGOANIME_BASE_URL=https://anitaku.to

# =============================================================================
# workstream raw-jp / Phase 01 — AllAnime raw-JP provider
# =============================================================================
# AllAnime exposes a GraphQL persisted-query API serving original Japanese
# audio HLS streams. The persisted-query SHA256 hashes occasionally rotate
# (~every few months); when AllAnime breaks the existing values, refresh
# from a browser network capture or upstream reference (pystardust/ani-cli,
# justfoolingaround/animdl). Empty values fall back to known-good defaults
# baked into the parser package.
#
# Ordered fallback domain list. The parser caches the first responsive
# domain in memory for the process lifetime.
# ALLANIME_DOMAINS=allanime.day,allmanga.to,allanime.to
#
# Persisted-query SHA256 hashes. Empty = use parser-baked defaults.
# ALLANIME_QUERY_SEARCH_SHA=
# ALLANIME_QUERY_EPISODES_SHA=
# ALLANIME_QUERY_SOURCES_SHA=
#
# Per-request HTTP timeout. Default 10s.
# ALLANIME_HTTP_TIMEOUT=10s
#
# Headers expected by AllAnime's WAF.
# ALLANIME_REFERER=https://allmanga.to/
# ALLANIME_USER_AGENT=AnimeEnigma/1.0

# =============================================================================
# Library Service (workstream raw-jp / v0.2) — port 8089
# =============================================================================
# The library service uses its own Postgres database, auto-created on first
# start via libs/database.New(). The default is `library` and rarely needs
# changing; override only if you need an isolated test database.
LIBRARY_DB_NAME=library
# All other LIBRARY_DB_* values inherit DB_HOST / DB_PORT / DB_USER /
# DB_PASSWORD from the shared Postgres credentials above. Phase 3 of the
# raw-jp workstream adds LIBRARY_TORRENT_* and LIBRARY_ENCODE_* knobs.

# =============================================================================
# workstream raw-jp / Phase 02 — Nyaa + AnimeTosho search clients
# =============================================================================
# The library service exposes GET /api/library/search?q=&mal_id=&limit=
# (admin-only via the gateway). It fans out across Nyaa.si (RSS) and
# AnimeTosho (JSON feed) in parallel, dedupes by InfoHash, and ranks
# AnimeTosho hits with a matching MAL ID first. Both endpoints are
# tolerant of upstream WAF nudges so the defaults rarely need changing.
#
# NYAA_BASE_URL=https://nyaa.si
# ANIMETOSHO_BASE_URL=https://feed.animetosho.org
#
# Per-request HTTP timeout (applied to both clients). Default 15s.
# LIBRARY_SEARCH_TIMEOUT=15s
#
# User-Agent sent on every search request. Both providers tolerate
# generic agents; override only if you need to identify your deployment
# to upstream operators.
# LIBRARY_SEARCH_UA=AnimeEnigma/1.0 (library service)
#
# Default + max page size for /api/library/search?limit=...
# LIBRARY_SEARCH_DEFAULT_LIMIT=50
# LIBRARY_SEARCH_MAX_LIMIT=200

# =============================================================================
# workstream raw-jp / Phase 03 — Torrent client + worker pool + disk guard
# =============================================================================
# The library service embeds github.com/anacrolix/torrent behind a thin
# facade and runs N workers (default 2) that claim queued jobs via
# FOR UPDATE SKIP LOCKED and drive them queued → downloading → encoding
# (Phase 4 picks up at encoding). Defaults are tuned for a self-hosted
# home server — override only if you know why.
#
# --- Torrent client ---
# Where downloaded payloads land. Mounted as the library_torrents
# Docker volume by default. Must be writable by the library container.
# LIBRARY_TORRENT_DOWNLOAD_DIR=/data/torrents
#
# Max concurrent peer connections per torrent. Lower this on
# bandwidth-constrained hosts; raise on fast pipes.
# LIBRARY_TORRENT_MAX_PEERS=80
#
# Upload-rate cap in KBPS. 0 = unlimited. Default 1024 (~1 MiB/s)
# keeps a home connection responsive while still being a good neighbor.
# LIBRARY_TORRENT_MAX_UPLOAD_RATE_KBPS=1024
#
# After download completes the client continues to seed for this
# window before dropping the torrent. Increase to be a better peer.
# LIBRARY_TORRENT_SEED_DURATION=24h
#
# Zero-peer dwell time before a job is marked failed with
# error_text="stalled: no peers for 30 minutes".
# LIBRARY_TORRENT_STALL_TIMEOUT=30m
#
# --- Worker pool ---
# Number of concurrent download goroutines. Default 2 is a good
# baseline; raise on hosts with abundant disk + bandwidth.
# LIBRARY_DOWNLOAD_WORKERS=2
#
# How often each worker re-reads handle.Progress() and persists
# progress_pct + emits library_download_bytes_total deltas.
# LIBRARY_DOWNLOAD_PROGRESS_TICK=5s
#
# --- Disk guard ---
# POST /api/library/jobs returns HTTP 507 {"error":"disk_full"} when
# the free-space percentage on LIBRARY_TORRENT_DOWNLOAD_DIR falls
# below this threshold. Default 20 is conservative — raise it on
# small disks, lower it on hosts with autoscaling storage.
# LIBRARY_DISK_FREE_MIN_PCT=20
#
# How often the disk guard refreshes the library_disk_free_bytes
# gauge.
# LIBRARY_DISK_POLL_INTERVAL=30s

# =============================================================================
# workstream raw-jp / Phase 04 — ffmpeg HLS transcoder + MinIO writer
# =============================================================================
# The library encoder worker claims status='encoding' jobs from
# library_jobs, transcodes the downloaded payload via ffmpeg (H.264 + AAC
# + 6s VOD HLS segments), uploads playlist + segments to MinIO under
# raw-library/{shikimori_id}/{episode}/ (or pending/{job_id}/{episode}/
# when shikimori_id is empty), and persists a library_episodes row.
# Defaults are tuned for a single self-hosted host with the compose-
# default MinIO root credentials.

# --- Encoder worker pool ---
# Number of concurrent encoder goroutines. ffmpeg is CPU-bound; raise
# only on hosts with abundant cores.
# LIBRARY_ENCODE_WORKERS=2

# Scratch dir for ffmpeg playlist + segments (per-call subdir auto-created
# under this root). Mounted as the library_minio_staging Docker volume.
# LIBRARY_ENCODE_TMPDIR=/tmp/encode

# Bitrate cap (kbps). Chosen bv = min(source bitrate via ffprobe, this
# cap), floored at 500 kbps. Default 5000 covers typical 1080p anime
# without bloating storage.
# LIBRARY_ENCODE_MAX_BITRATE_KBPS=5000

# Paths to the ffmpeg + ffprobe binaries baked into the library image
# (Alpine's `ffmpeg` package installs both here by default).
# LIBRARY_FFMPEG_BIN=/usr/bin/ffmpeg
# LIBRARY_FFPROBE_BIN=/usr/bin/ffprobe

# --- MinIO writer ---
# Connection to the compose-default minio service. The library service
# reads its own LIBRARY_MINIO_* env vars (not the streaming service's
# MINIO_*) so the two services stay independent.
# LIBRARY_MINIO_ENDPOINT=minio:9000
# LIBRARY_MINIO_ACCESS_KEY=minioadmin
# LIBRARY_MINIO_SECRET_KEY=minioadmin
# LIBRARY_MINIO_BUCKET=raw-library
# LIBRARY_MINIO_USE_SSL=false

# Per-job upload-pool size for HLS segments. Segments upload concurrently
# via errgroup.SetLimit(N); the playlist always uploads LAST on the main
# goroutine so HLS clients never see a playlist referring to an
# unfinished segment. Default 8 is well below MinIO's connection-pool cap.
# LIBRARY_MINIO_UPLOAD_CONCURRENCY=8

# =============================================================================
# workstream raw-jp / Phase 06 (v0.2) — Hybrid Resolver
# =============================================================================
# The catalog's raw resolver calls the library service FIRST for every
# /api/anime/{uuid}/raw/stream request. When library_episodes has a row
# for (shikimori_id, episode), the catalog returns the MinIO HLS URL
# with source:"library". Otherwise it falls back to AllAnime with
# source:"allanime". Per-request library timeout is 2s — the library
# is on the docker network, so any longer wait means it's actually down.
#
# Catalog → library (the hybrid lookup):
# LIBRARY_API_URL=http://library:8089
# LIBRARY_API_TIMEOUT=2s
#
# Library → catalog (cache-invalidation webhook after every successful
# encode). The catalog mounts POST /internal/cache/invalidate/raw/{id}
# OUTSIDE /api — reachable only from within the docker network because
# nginx/gateway does not proxy /internal/*. Best-effort: a failed
# webhook is logged + counted via library_cache_invalidation_total{
# result="fail"} but never fails the encoder job. The 1h source-
# decision TTL covers correctness even if every webhook fails.
# CATALOG_INTERNAL_API_URL=http://catalog:8081
# CATALOG_INTERNAL_API_TIMEOUT=3s

# =============================================================================
# workstream raw-jp / Phase 02 — OpenSubtitles v1 REST
# =============================================================================
# OpenSubtitles aggregates multi-language subtitles (RU/EN/etc.) alongside
# Jimaku's JP catalogue via the subs aggregator service. Get an API key at
# https://www.opensubtitles.com/en/consumers (free tier covers our use).
#
# OPENSUBTITLES_API_KEY=
# OPENSUBTITLES_USER_AGENT=AnimeEnigma/1.0
# OPENSUBTITLES_TIMEOUT=10s

# Rooms service — comma-separated list of allowed WebSocket origins.
# REQUIRED in prod. Empty value = WS rejects all connections.
# Example: ALLOWED_WS_ORIGINS=https://animeenigma.org,https://animeenigma.ru,http://localhost:5173
ALLOWED_WS_ORIGINS=

# =============================================================================
# workstream notifications, v1.0 Phase 1 — Notifications service
# =============================================================================
# The notifications service lives on port 8090 (8087 was unavailable: host
# maintenance bot already bound there; same blocker that pushed library
# to 8089). The gateway resolves /api/notifications/* against this URL.
# NOTIFICATIONS_SERVICE_URL=http://notifications:8090

# =============================================================================
# workstream notifications, v1.0 Phase 2 — Detector + cleanup cron
# =============================================================================
# Catalog base URL the detector hits for /internal/anime/{id}/episodes.
# CATALOG_URL=http://catalog:8081
#
# Rollback toggle (D-RB-01) — set to false to disable scheduler at boot.
# CRUD + producer endpoint still work; no cron-driven creates / cleanup.
# NOTIFICATIONS_DETECTOR_ENABLED=true
#
# Detector schedule (Phase 2 default: hourly on the hour with ±5min boot
# jitter). Cleanup schedule (Phase 2 default: 03:30 daily).
# NOTIFICATIONS_DETECTOR_CRON=0 * * * *
# NOTIFICATIONS_CLEANUP_CRON=30 3 * * *
#
# Retention window (days) for the cleanup DELETE. NOTIF-DET-09 default 30.
# NOTIFICATIONS_RETENTION_DAYS=30
#
# Per-combo parser fan-out cap + per-call timeout.
# NOTIFICATIONS_DETECTOR_WORKER_LIMIT=5
# NOTIFICATIONS_PARSER_TIMEOUT=10s
#
# Active-unread gauge poll interval. Backed by idx_user_unread partial index.
# NOTIFICATIONS_UNREAD_GAUGE_INTERVAL=5m

# =============================================================================
# workstream notifications, v1.0 Phase 3 — Frontend bell + dropdown + toast
# =============================================================================
# Feature flag baked into the Vite bundle at web-build time. Set to false to
# hide the notification bell + disable polling (Phase 3 rollback flag).
# Defaults to true when unset. Mirrors frontend/web/.env.example.
VITE_NOTIFICATIONS_ENABLED=true

# =============================================================================
# Watch Together (workstream watch-together, v1.0 Phase 1)
# =============================================================================
# Service port (default 8091). Next free after notifications:8090.
# WATCH_TOGETHER_PORT=8091
#
# JWT secret. Falls back to the shared JWT_SECRET when not overridden.
# WATCH_TOGETHER_JWT_SECRET=${JWT_SECRET}
#
# Redis sliding TTL on wt:room:{id}* keys. Refreshed on every inbound event;
# 5min grace timer after last member disconnects (no refresh during grace,
# keys expire naturally).
# WATCH_TOGETHER_ROOM_TTL=15m
# WATCH_TOGETHER_GRACE_PERIOD=5m
#
# Max members per room (WT-NF-02 hard cap; default 10).
# WATCH_TOGETHER_MAX_MEMBERS=10
#
# Public origin for invite URLs and ws_url responses from POST /rooms.
# Production default: https://animeenigma.org. Override for dev/staging.
# WATCH_TOGETHER_PUBLIC_BASE_URL=https://animeenigma.org
#
# Origin allowlist gate for the WS upgrade CheckOrigin. Production should be
# left as default (false) so only WATCH_TOGETHER_PUBLIC_BASE_URL's origin
# is accepted. Dev: set to true to accept any Origin.
# WATCH_TOGETHER_ALLOW_ALL_ORIGINS=false
#
# Gateway service URL (gateway → watch-together). Internal docker-network DNS.
# WATCH_TOGETHER_SERVICE_URL=http://watch-together:8091

# =============================================================================
# Domain + HLS subdomain (Phase 2 .ru → .org migration)
# =============================================================================
# Public-facing site URL used for OG meta tags and gateway SiteURL.
# SITE_URL=https://animeenigma.org
#
# HLS subdomain: route heavy segment traffic to a dedicated subdomain to
# isolate it from the app's API rate zone. Leave empty for same-origin.
# VITE_HLS_PROXY_BASE=https://stream.animeenigma.org
#
# Magic-link SSO target: the .org domain that Generate(ru) redirects to.
# Used by services/auth for cross-domain session handoff.
# MAGIC_LINK_TARGET_BASE=https://animeenigma.org

# =============================================================================
# workstream hero-spotlight, v1.0 Phase 1 — Spotlight aggregator
# =============================================================================
# SPOTLIGHT_ENABLED gates GET /api/home/spotlight. When false the catalog
# handler returns a bare 404 (no body) so the frontend HSB-FE-02 v-if
# hides the block. Default true. Set to "false" as a kill switch if the
# aggregator misbehaves in production.
SPOTLIGHT_ENABLED=true

# Analytics clickstream (Plan 1)
ANALYTICS_IP_SALT=change-me-in-production

# Analytics EventStore backend (v4.0 Activity Register Phase 1 — 01-03).
#   postgres   = original behaviour, Postgres only (safe rollback target)
#   clickhouse = ClickHouse only (full cutover; CH must be reachable at boot)
#   dualwrite  = write to BOTH; Postgres is the source of truth + dashboard
#                fallback, ClickHouse is best-effort. This is the safe migration
#                default — a CH outage can never fail the live PG write.
ANALYTICS_STORE_BACKEND=dualwrite

# =============================================================================
# ClickHouse unified event plane (v4.0 Activity Register Phase 1 — AR-STORE-01)
# =============================================================================
# Credentials for the dedicated CH user (T-01-02). The prod host MUST set a
# non-empty password here — do NOT run CH on the empty-password `default` user.
# The compose default (changeme) is a placeholder only; override it in .env.
CLICKHOUSE_USER=analytics
CLICKHOUSE_PASSWORD=change-me-in-production

# --- stealth-scraper RAM budget + per-user quota (Phase 2) ---
# The Camoufox pool is governed by combined process-tree RSS, not a fixed count.
# Soft = stop warming + evict idle; hard = refuse a new browser launch
# (503 kind=capacity) + evict the LRU idle session. STEALTH_POOL_SIZE is only a
# fail-safe ceiling used if the /proc RSS read fails.
# Host-fit defaults: the budget lives INSIDE the existing 3500m container
# (mem_limit unchanged) on this RAM-tight box. Raise both (and mem_limit) only
# on a host with the headroom — e.g. 4 GiB/6 GiB needs mem_limit ~7g.
STEALTH_RAM_SOFT_BYTES=2147483648   # 2 GiB
STEALTH_RAM_HARD_BYTES=3221225472   # 3 GiB
STEALTH_RAM_SAMPLE_SECONDS=5
# Max concurrent stealth sessions per user (authed id or salted client-IP).
STEALTH_USER_QUOTA=2
# Salt for the anonymous-fallback per-IP quota key (catalog → scraper user_key).
# Rotated daily with the UTC date; empty still hashes. Set to a random secret.
CATALOG_IP_SALT=

# =============================================================================
# upscaler service — untrusted-worker capability secret
# =============================================================================
# HMAC key that gates the ENTIRE untrusted-worker control + data plane
# (session/segment/job capability handles). A worker that learns this key could
# forge any capability/session, so it MUST be a real secret in prod and MUST
# NOT be committed. The compose default is EMPTY on purpose: an empty secret
# makes the capability package fail-closed (Enabled()=false → Mint/Verify
# return ""/false → the upscaler refuses to mint handles), so the service can
# never silently run with a public/dev key.
# REQUIRED in prod — 64+ hex chars, e.g. openssl rand -hex 32; empty = capability fail-closed (service refuses to mint handles)
JOB_CAPABILITY_SECRET=
