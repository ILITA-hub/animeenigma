<?xml version="1.0"?>
<!--
  ClickHouse native Prometheus self-metrics endpoint (AR-STORE-01).
  Exposes metrics/events/asynchronous_metrics on :9363 at /metrics.
  Scraped by Prometheus via the 'clickhouse' job (docker/prometheus/prometheus.yml).
  Mounted read-only at /etc/clickhouse-server/config.d/ by the clickhouse service.
-->
<clickhouse>
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>
</clickhouse>
