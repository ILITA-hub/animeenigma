      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "provider": 0, "server": 1, "reason": 2, "Value": 3 }, "renameByName": { "Value": "Fail Count (24h)" } } } ],
      "type": "table"
    }
  ],
