    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "description": "Merged provider roster (Postgres stream_providers — source of truth) + live playback verdict (daily honest probe). One row per provider: the operator Policy (Auto = in auto-failover chain · Manual-only = pinnable but excluded from failover · Off = not registered — what we set), the probed Playability (up/degraded/down — what we measured), how each stream is Resolved via (scraper microservice + engine — 'Camoufox' = stealth browser sidecar, 'HTTP' = direct fetch — vs catalog parser, FE iframe, or self-hosted), the probed Playability (up/degraded/down), and the top-3 failure Reasons with the anime title each failed on. Non-probed providers (Kodik/AniLib/Hanime/Raw/18anime/ae) show '— not probed'. Filtered by $provider for the probe columns.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "UP": {
                        "color": "green",
                        "index": 0,
                        "text": "UP"
                      },
                      "Recovering": {
                        "color": "yellow",
                        "index": 1,
                        "text": "Recovering"
                      },
                      "Failing": {
                        "color": "orange",
                        "index": 2,
                        "text": "Failing"
                      },
                      "Manual-only": {
                        "color": "red",
                        "index": 3,
                        "text": "Manual-only"
                      },
                      "Off": {
                        "color": "dark-red",
                        "index": 4,
                        "text": "Off"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved via"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 150
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Playability"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "regex",
                    "options": {
                      "pattern": "^up",
                      "result": {
                        "color": "green",
                        "index": 0
                      }
                    }
                  },
                  {
                    "type": "regex",
                    "options": {
                      "pattern": "^degraded",
                      "result": {
                        "color": "orange",
                        "index": 1
                      }
                    }
                  },
                  {
                    "type": "regex",
                    "options": {
                      "pattern": "^down",
                      "result": {
                        "color": "red",
                        "index": 2
                      }
                    }
                  },
                  {
                    "type": "special",
                    "options": {
                      "match": "null",
                      "result": {
                        "text": "— not probed",
                        "color": "text",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Probe run"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 170
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Reasons"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 640
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Description"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 380
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "AI Probe Notes"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 460
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Provider"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Group"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 102,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Playability"
          }
        ]
      },
      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "aenigma-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT name AS provider, \"group\" AS \"Group\", policy AS \"Policy\", health AS \"Health\", CASE WHEN policy = 'disabled' THEN 'Off' WHEN policy = 'auto' AND health = 'up' THEN 'UP' WHEN health = 'recovering' THEN 'Recovering' WHEN policy = 'auto' AND health = 'down' THEN 'Failing' ELSE 'Manual-only' END AS \"State\", last_probed_at AS \"Last probed\", CASE WHEN scraper_operated AND engine = 'browser' THEN 'scraper · Camoufox' WHEN scraper_operated THEN 'scraper · HTTP' WHEN name = 'ae' THEN 'self-hosted' WHEN name = 'kodik-iframe' THEN 'FE iframe' ELSE 'catalog parser' END AS \"Resolved via\", description AS \"Description\", ai_probe_notes AS \"AI Probe Notes\" FROM stream_providers ORDER BY scraper_operated DESC, \"group\", name",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "queryType": "sql",
          "format": "table",
          "rawSql": "SELECT provider, concat(multiIf(countIf(playable = 1) > 0, 'up', countIf(stage = 'playback') > 0, 'degraded', 'down'), ' (', toString(countIf(playable = 1)), '/', toString(count()), ')') AS playability, max(run_ts) AS probed_at, arrayStringConcat(topKIf(3)(label, playable = 0), ' · ') AS reasons FROM (  SELECT provider, stage, playable, run_ts,          concat(reason, ' — ', if(empty(anime_name), 'anime', anime_name)) AS label   FROM probe_runs WHERE (provider, run_ts) IN (SELECT provider, max(run_ts) FROM probe_runs WHERE run_ts > now() - INTERVAL 48 HOUR GROUP BY provider)) GROUP BY provider ORDER BY provider",
          "refId": "B"
        }
      ],
      "title": "Provider Roster & Playability",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "provider",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Health": true,
              "Last probed": true
            },
            "indexByName": {
              "provider": 0,
              "State": 1,
              "Policy": 2,
              "playability": 3,
              "AI Probe Notes": 4,
              "Description": 5,
              "reasons": 6,
              "probed_at": 7,
              "Group": 8,
              "Resolved via": 9,
              "Last probed": 10
            },
            "renameByName": {
              "provider": "Provider",
              "playability": "Playability",
              "probed_at": "Probe run",
              "reasons": "Reasons"
            }
          }
        }
      ],
      "type": "table"
    },
