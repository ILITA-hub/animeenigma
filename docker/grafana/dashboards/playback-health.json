    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Which providers the failover chain moved AWAY from over the selected range \u2014 i.e. how often each provider failed and triggered a fallback. Higher = less reliable as a primary. One bar per provider.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "min": 0,
          "unit": "short"
