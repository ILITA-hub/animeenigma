          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "provider_health_up{provider=~\"$provider\", stage=~\"$stage\"}",
          "legendFormat": "{{ provider }}/{{ stage }}",
          "refId": "A"
        }
      ],
