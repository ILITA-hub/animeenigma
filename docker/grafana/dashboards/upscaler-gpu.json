          "rawQuery": true,
          "queryType": "sql",
          "format": "timeseries",
          "refId": "A",
          "rawSql": "SELECT ts AS time, concat(worker_id, ' used') AS series, vram_used_b AS value FROM analytics.upscale_worker_telemetry WHERE $__timeFilter(ts) AND worker_id IN (${worker_id:sql}) UNION ALL SELECT ts AS time, concat(worker_id, ' total') AS series, vram_total_b AS value FROM analytics.upscale_worker_telemetry WHERE $__timeFilter(ts) AND worker_id IN (${worker_id:sql}) ORDER BY time"
        }
