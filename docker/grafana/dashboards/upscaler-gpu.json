          "format": "timeseries",
          "refId": "A",
          "rawSql": "SELECT ts AS time, worker_id, gpu_util FROM analytics.upscale_worker_telemetry WHERE $__timeFilter(ts) AND worker_id IN (${worker_id:sql}) ORDER BY ts"
