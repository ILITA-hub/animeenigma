          "rawQuery": true,
          "queryType": "sql",
          "format": "timeseries",
          "refId": "A",
          "rawSql": "SELECT ts AS time, worker_id, toFloat64(vram_used_b) / toFloat64(vram_total_b) AS vram_ratio FROM analytics.upscale_worker_telemetry WHERE $__timeFilter(ts) AND worker_id IN (${worker_id:sql}) AND vram_total_b > 0 ORDER BY ts"
