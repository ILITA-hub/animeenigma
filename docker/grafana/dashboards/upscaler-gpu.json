    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "description": "Latest telemetry snapshot per selected worker — GPU model, image version, and current sensor readings.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "id": 10,
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "queryType": "sql",
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT worker_id, gpu_model, image_version, argMax(gpu_util, ts) AS gpu_util, formatReadableSize(argMax(vram_used_b, ts)) AS vram_used, formatReadableSize(argMax(vram_total_b, ts)) AS vram_total, argMax(gpu_temp_c, ts) AS temp_c, argMax(gpu_power_w, ts) AS power_w, argMax(decode_fps, ts) AS decode_fps, argMax(inference_fps, ts) AS inference_fps, argMax(encode_fps, ts) AS encode_fps, max(ts) AS last_seen FROM analytics.upscale_worker_telemetry WHERE $__timeFilter(ts) AND worker_id IN (${worker_id:sql}) GROUP BY worker_id, gpu_model, image_version ORDER BY last_seen DESC"
        }
      ],
      "title": "Worker Snapshot (latest readings per worker)",
      "type": "table"
    }
