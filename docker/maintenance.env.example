# Maintenance bot config — copy to maintenance.env (gitignored) and fill in real values.
#
# This file is a template. Real secrets MUST live in docker/maintenance.env, which is
# excluded from git via .gitignore. Never commit a populated maintenance.env.

# === Telegram bots ===
# Maintenance bot — receives admin commands, replies with diagnoses.
# Get a token from @BotFather. Separate from the alerts bot below — they need
# distinct identities so the maintenance bot can read the alerts bot's messages.
TELEGRAM_BOT_TOKEN=replace-with-maintenance-bot-token

# Alerts bot — used by Grafana / player service to push alerts. Kept here for
# reference; the maintenance daemon doesn't authenticate as this bot, just observes.
TELEGRAM_ALERTS_BOT_TOKEN=replace-with-alerts-bot-token

# Admin chat / users
TELEGRAM_ADMIN_CHAT_ID=replace-with-admin-chat-id
ADMIN_USERNAMES=admin1,admin2

# === Claude integration ===
CLAUDE_PATH=/root/.local/bin/claude
PROJECT_ROOT=/data/animeenigma
MAINTENANCE_PROMPT_PATH=.claude/maintenance-prompt.md
STATE_PATH=.claude/maintenance-state.json
ISSUES_PATH=docs/issues/issues.json
DEFAULT_MODEL=sonnet
CODE_FIX_MODEL=opus
CLAUDE_TIMEOUT_SEC=1200

# === Server ===
SERVER_PORT=8087

# Alerts arrive ONLY via the inbound Grafana webhook (POST /api/grafana-webhook,
# secured by GRAFANA_WEBHOOK_USER/PASS above). Removed 2026-07-15:
#   GRAFANA_URL / GRAFANA_POLL_INTERVAL / GRAFANA_API_USER / GRAFANA_API_PASS
#     — the outbound alertmanager reconcile poll. It bypassed Grafana's
#       notification policy (mute timings are invisible on the v2/alerts API),
#       paging for deliberately-muted alerts (AUTO-616/618).
#   SUPPRESSED_ALERTS
#     — never worked (parsed on ";", deployed with ","). To stop an alert
#       paging, set `severity: diagnostic` on the rule, or add a muted route,
#       in docker/grafana/provisioning/alerting/.

# === Test mode (Phase 23 Plan 23-03) ===
# Reserved future-hook for integration tests. When set to "true", the
# dispatcher MAY short-circuit before invoking the Claude CLI / Telegram
# client — letting synthetic Grafana alerts be posted at a live binary
# without triggering a real fix. Plan 23-03 only plumbs the field on the
# config struct; consuming callers land in a future plan. Leave at "false"
# in production. Recognized values: "true" (enable) or anything else
# (disable, including unset).
MAINTENANCE_TEST_MODE=false
