      "source": "grafana_alert",
      "category": "monitoring",
      "priority": "P2",
      "status": "resolved",
      "title": "False P0: calendar_sync weekly job trips 25h staleness alert",
      "reporter": "grafana",
      "telegram_message_id": 0,
      "affected_service": "scheduler",
      "actions": [
        {
          "action": "Edit rules.yml: scheduler-sync-stale expression",
          "result": "success",
          "details": "Changed expr from `time() - scheduler_job_last_success_timestamp` to `time() - scheduler_job_last_success_timestamp{exported_job!=\"calendar_sync\"}` — excludes weekly calendar_sync from 25h check. Used `exported_job` (not `job`) because Prometheus renames the metric label."
        },
        {
          "action": "Add scheduler-calendar-sync-stale rule",
          "result": "success",
          "details": "New rule with uid=scheduler-calendar-sync-stale, threshold=691200s (8 days), severity=warning, targeting only exported_job=\"calendar_sync\""
        },
        {
          "action": "docker restart animeenigma-grafana",
          "result": "success",
          "details": "Restarted Grafana to reload provisioned alert rules. Required 2 restarts: first to apply calendar_sync exclusion, second to fix job→exported_job label after discovering Prometheus renames the label."
        },
        {
          "action": "Verify alert resolution",
          "result": "success",
          "details": "Grafana alertmanager API confirms no scheduler/calendar alerts firing. Both rules loaded correctly with exported_job labels."
        }
      ],
      "resolution": "Fix applied by @tNeymik"
    }
