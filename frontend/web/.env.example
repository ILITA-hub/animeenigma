# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_SOCKET_URL=http://localhost:8000

# Application Configuration
VITE_APP_NAME=AnimeEnigma
VITE_APP_VERSION=1.0.0

# Workstream raw-jp / Phase 04 — feature flag for the "RAW JP" video
# provider chip and RawPlayer component. Default false in production until
# live ui_audit_bot smoke test passes. Set to true in development /
# .env.development / .env.test to surface the chip.
VITE_RAW_PROVIDER_ENABLED=false

# Workstream notifications / Phase 3 — feature flag for the header bell,
# dropdown, toast, and polling lifecycle. Set to false to hide the
# notification bell + disable polling (Phase 3 rollback flag). Defaults
# to true when unset.
VITE_NOTIFICATIONS_ENABLED=true
