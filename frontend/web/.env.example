# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_SOCKET_URL=http://localhost:8000

# Application Configuration
VITE_APP_NAME=AnimeEnigma
VITE_APP_VERSION=1.0.0

# Workstream notifications / Phase 3 — feature flag for the header bell,
# dropdown, toast, and polling lifecycle. Set to false to hide the
# notification bell + disable polling (Phase 3 rollback flag). Defaults
# to true when unset.
VITE_NOTIFICATIONS_ENABLED=true

# Workstream hero-spotlight / Phase 02 — feature flag for the
# HeroSpotlightBlock (4-card auto-cycling carousel at top of Home view).
# Defaults to true when unset. Set to 'false' (literal string) to disable
# the block; the legacy trendingRecs row stays visible (Phase 2 transitional
# dual-flag state — Phase 3 removes trendingRecs).
VITE_HERO_SPOTLIGHT_ENABLED=true

VITE_ANALYTICS_ENABLED=true              # Clickstream analytics snippet (Plan 2)
