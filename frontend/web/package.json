{
  "name": "animeenigma-web",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.json --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.json --fix --ignore-path .gitignore",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@vueuse/core": "^14.1.0",
    "ass-compiler": "^0.1.16",
    "axios": "^1.17.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "hls.js": "~1.5.20",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.4",
    "reka-ui": "2.9.8",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "3.6.0",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.11.25",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "jsdom": "^29.1.1",
    "jsonc-eslint-parser": "^3.1.0",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.4.2",
    "vite": "^5.4.21",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.6",
    "vue-tsc": "^2.0.7"
