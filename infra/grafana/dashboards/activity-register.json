{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "activity-register",
  "title": "Activity Register",
  "description": "Unified Activity Register dashboard over ClickHouse analytics.events (collapses the former Awareness Overview, Flow, and Pivot dashboards into one). Sections: (1) Awareness Overview — AR-REPORT-04 top operations + top external dependencies + the AR-REPORT-03 explainable avg+Nσ volume-anomaly panel (tune with $sigma / $window). (2) Flow — AR-REPORT-02 origin → operation → target drill via groupBy transform. (3) Pivot — AR-REPORT-01 wide-event pivot, regroup live via $group_by. Byte/anomaly measures filter source='be' AND effect_kind='egress' so fe_rum approximate rows never contaminate authoritative egress totals (AR-FE-03).",
  "tags": ["activity-register"],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "sigma",
        "label": "σ multiplier",
        "type": "custom",
        "description": "Standard-deviation multiplier for the anomaly threshold (baseline_avg + $sigma * stddevPop). Higher = quieter.",
        "query": "1,2,3,4,5",
        "options": [
          { "text": "1", "value": "1", "selected": false },
          { "text": "2", "value": "2", "selected": false },
          { "text": "3", "value": "3", "selected": true },
          { "text": "4", "value": "4", "selected": false },
          { "text": "5", "value": "5", "selected": false }
        ],
        "current": { "text": "3", "value": "3" },
        "includeAll": false,
        "multi": false
      },
      {
        "name": "window",
        "label": "Baseline window (hours)",
        "type": "custom",
        "description": "Trailing window (hours) over which the per-operation baseline is computed.",
        "query": "6,12,24,48,72",
        "options": [
          { "text": "6", "value": "6", "selected": false },
          { "text": "12", "value": "12", "selected": false },
          { "text": "24", "value": "24", "selected": true },
          { "text": "48", "value": "48", "selected": false },
          { "text": "72", "value": "72", "selected": false }
        ],
        "current": { "text": "24", "value": "24" },
        "includeAll": false,
        "multi": false
      },
      {
        "name": "group_by",
        "label": "Group by",
        "type": "custom",
        "query": "origin, operation, effect_kind, target_kind, target, source",
        "includeAll": false,
        "multi": false,
        "current": {
          "text": "operation",
          "value": "operation"
        },
        "options": [
          { "text": "origin", "value": "origin", "selected": false },
          { "text": "operation", "value": "operation", "selected": true },
          { "text": "effect_kind", "value": "effect_kind", "selected": false },
          { "text": "target_kind", "value": "target_kind", "selected": false },
          { "text": "target", "value": "target", "selected": false },
          { "text": "source", "value": "source", "selected": false }
        ]
      },
      {
        "name": "effect_kind",
        "label": "Effect kind",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "aenigma-clickhouse"
        },
        "query": "SELECT DISTINCT effect_kind FROM events WHERE effect_kind != '' AND $__timeFilter(timestamp) ORDER BY effect_kind",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "origin",
        "label": "Origin",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "aenigma-clickhouse"
        },
        "query": "SELECT DISTINCT origin FROM events WHERE origin != '' AND $__timeFilter(timestamp) ORDER BY origin",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "aenigma-clickhouse"
        },
        "query": "SELECT DISTINCT target FROM events WHERE target != '' AND $__conditionalAll(effect_kind IN (${effect_kind:singlequote}), $effect_kind) AND $__timeFilter(timestamp) ORDER BY target LIMIT 200",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Awareness Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Active anomaly count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT count() AS anomalies FROM ( WITH hourly AS (SELECT operation, toStartOfHour(timestamp) AS h, sum(requests) AS req FROM events WHERE timestamp >= now() - INTERVAL $window HOUR AND effect_kind = 'egress' AND source = 'be' GROUP BY operation, h), stats AS (SELECT operation, avgIf(req, h < toStartOfHour(now())) AS baseline_avg, stddevPopIf(req, h < toStartOfHour(now())) AS baseline_sd, anyIf(req, h = toStartOfHour(now() - INTERVAL 1 HOUR)) AS last_req FROM hourly GROUP BY operation) SELECT operation, last_req > baseline_avg + $sigma * baseline_sd AS is_anomaly FROM stats WHERE baseline_avg > 0 ) WHERE is_anomaly"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Top operations (now/today)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 2,
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT operation, sum(requests) AS requests, round(avg(duration_ms), 1) AS avg_ms FROM events WHERE $__timeFilter(timestamp) AND operation != '' GROUP BY operation ORDER BY requests DESC LIMIT 10"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Top external dependencies (egress, source=be)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 3,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "bytes" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT target AS dependency, sum(requests) AS requests, sum(bytes_out + bytes_in) AS bytes FROM events WHERE $__timeFilter(timestamp) AND effect_kind = 'egress' AND source = 'be' GROUP BY target ORDER BY bytes DESC LIMIT 10"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Active volume anomalies (avg + $sigma·σ over $window h)",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 },
      "id": 4,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "is_anomaly" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "ok" }, "1": { "text": "ANOMALY" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "is_anomaly", "desc": true }] },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "WITH hourly AS (SELECT operation, toStartOfHour(timestamp) AS h, sum(requests) AS req FROM events WHERE timestamp >= now() - INTERVAL $window HOUR AND effect_kind = 'egress' AND source = 'be' GROUP BY operation, h), stats AS (SELECT operation, avgIf(req, h < toStartOfHour(now())) AS baseline_avg, stddevPopIf(req, h < toStartOfHour(now())) AS baseline_sd, anyIf(req, h = toStartOfHour(now() - INTERVAL 1 HOUR)) AS last_req FROM hourly GROUP BY operation) SELECT operation, last_req, round(baseline_avg, 1) AS baseline_avg, round(baseline_avg + $sigma * baseline_sd, 1) AS threshold, last_req > baseline_avg + $sigma * baseline_sd AS is_anomaly FROM stats WHERE baseline_avg > 0 ORDER BY (last_req - baseline_avg) / nullIf(baseline_sd, 0) DESC"
        }
      ]
    },
    {
      "type": "row",
      "title": "Flow (from → choke-point → effects)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 101,
      "panels": []
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "From → choke-point → effects (origin → operation → target)",
      "type": "table",
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 5,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "bytes"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "origin": {
                "aggregations": [],
                "operation": "groupby"
              },
              "operation": {
                "aggregations": [],
                "operation": "groupby"
              },
              "dependency": {
                "aggregations": [],
                "operation": "groupby"
              },
              "requests": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              },
              "bytes": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              }
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT origin, operation, target AS dependency, sum(requests) AS requests, sum(bytes_out + bytes_in) AS bytes FROM events WHERE $__timeFilter(timestamp) AND effect_kind = 'egress' AND source = 'be' AND $__conditionalAll(origin IN (${origin:singlequote}), $origin) GROUP BY origin, operation, target ORDER BY bytes DESC LIMIT 200"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pivot",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 102,
      "panels": []
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Pivot — grouped by ${group_by}",
      "type": "table",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "id": 6,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "bytes_be"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT ${group_by} AS dimension, sum(requests) AS requests, sumIf(bytes_out + bytes_in, source = 'be') AS bytes_be, round(avg(duration_ms), 1) AS avg_ms FROM events WHERE $__timeFilter(timestamp) AND $__conditionalAll(effect_kind IN (${effect_kind:singlequote}), $effect_kind) AND $__conditionalAll(origin IN (${origin:singlequote}), $origin) AND $__conditionalAll(target IN (${target:singlequote}), $target) GROUP BY dimension ORDER BY requests DESC LIMIT 100"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Requests over time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 55
      },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": 0,
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT toStartOfHour(timestamp) AS time, sum(requests) AS requests FROM events WHERE $__timeFilter(timestamp) AND $__conditionalAll(effect_kind IN (${effect_kind:singlequote}), $effect_kind) AND $__conditionalAll(origin IN (${origin:singlequote}), $origin) AND $__conditionalAll(target IN (${target:singlequote}), $target) GROUP BY time ORDER BY time"
        }
      ]
    }
  ]
}
