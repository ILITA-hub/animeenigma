              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 63
      },
      "id": 21,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "aenigma-postgres-library"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN storage IS NULL THEN 'COMBINED' ELSE storage END AS \"Backend\",\n  COUNT(*) AS \"Episode copies\",\n  COALESCE(SUM(size_bytes),0) AS \"Size\",\n  COUNT(DISTINCT (shikimori_id, episode_number)) AS \"Distinct episodes\"\nFROM library_episodes\nGROUP BY ROLLUP(storage)\nORDER BY storage NULLS LAST",
          "refId": "A"
        }
      ],
      "title": "Storage by backend (episodes + bytes, with combined total)",
