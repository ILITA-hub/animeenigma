    {
      "datasource": {
        "type": "postgres",
        "uid": "aenigma-postgres-library"
      },
      "description": "Most recent episodes the autocache (and admin) wrote into the first-party pool (library DB). 'Release / path' is the chosen torrent title; Source = autocache | admin.",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Size"
            },
