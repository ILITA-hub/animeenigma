      },
      "id": 14,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "aenigma-postgres-library"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(e.downloaded_at, e.created_at) AS \"Downloaded\",\n  e.source AS \"Source\",\n  e.shikimori_id AS \"MAL ID\",\n  e.episode_number AS \"Ep\",\n  COALESCE(NULLIF(j.quality, ''), '') AS \"Quality\",\n  COALESCE(NULLIF(j.title, ''), e.minio_path) AS \"Release / path\",\n  e.size_bytes AS \"Size\",\n  e.fetch_count AS \"Fetches\",\n  e.last_fetch_at AS \"Last fetch\"\nFROM library_episodes e\nLEFT JOIN library_jobs j ON j.id = e.job_id\nORDER BY COALESCE(e.downloaded_at, e.created_at) DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Latest downloaded episodes (autocache pool)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "aenigma-postgres"
      },
      "description": "Last 10 sub-combo watch events that drive the autocache (any SUB = raw JP audio, plus the ae/raw players): WHO watched, WHEN, WHAT anime + episode, and the combo. Correlate to the downloads above by MAL ID. Note: the autocache demand is user-agnostic (deduped per mal/episode), so this is the watch-side trigger signal, not a per-download FK.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 78
      },
      "id": 15,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "aenigma-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  wp.last_watched_at AS \"When\",\n  COALESCE(u.username, wp.user_id::text) AS \"Who\",\n  COALESCE(NULLIF(a.name_en, ''), a.name) AS \"Anime\",\n  a.shikimori_id AS \"MAL ID\",\n  wp.episode_number AS \"Ep watched\",\n  COALESCE(pref.player,'?') || ' / ' || COALESCE(pref.language,'?') || ' / ' || COALESCE(pref.watch_type,'?') AS \"Combo\",\n  a.status AS \"Anime status\"\nFROM watch_progress wp\nJOIN animes a ON a.id = wp.anime_id\nLEFT JOIN user_anime_preferences pref ON pref.user_id::text = wp.user_id::text AND pref.anime_id::text = wp.anime_id::text\nLEFT JOIN users u ON u.id::text = wp.user_id::text\nWHERE (pref.watch_type = 'sub' OR pref.player IN ('ae','raw'))\nORDER BY wp.last_watched_at DESC\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Autocache triggers \u2014 who / when / what watched (last 10)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "aenigma-postgres-library"
      },
      "description": "CAUSE -> EFFECT: each user-driven autocache trigger (player Logic B next_ep + catalog backfill) and the download it produced. Left = the watch (who / combo / watched ep); right (-> columns) = the episode the autocache fetched as a result + its current status (no job yet -> queued -> downloading -> in pool). Joined exactly by (MAL ID, fetched ep). The aggregate scheduler Logic A push has no single user, so it is not listed here (see the by-trigger metrics + the downloads table).",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 86
      },
      "id": 16,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "aenigma-postgres-library"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  t.created_at AS \"Triggered\",\n  COALESCE(NULLIF(t.username,''), NULLIF(t.user_id,''), '?') AS \"Who\",\n  t.reason AS \"Trigger\",\n  COALESCE(NULLIF(t.watch_player,''),'?') || '/' || COALESCE(NULLIF(t.watch_language,''),'?') || '/' || COALESCE(NULLIF(t.watch_type,''),'?') AS \"Combo\",\n  t.watched_episode AS \"Watched ep\",\n  t.mal_id AS \"MAL ID\",\n  t.target_episode AS \"-> Fetched ep\",\n  COALESCE(NULLIF(j.title,''), '(searching / no release yet)') AS \"-> Downloaded release\",\n  CASE WHEN e.id IS NOT NULL THEN 'in pool' ELSE COALESCE(j.status::text, 'no job yet') END AS \"-> Effect\",\n  e.downloaded_at AS \"-> In pool at\"\nFROM autocache_trigger_log t\nLEFT JOIN LATERAL (\n  SELECT title, status FROM library_jobs\n  WHERE shikimori_id = t.mal_id AND episode = t.target_episode AND source='autocache'\n  ORDER BY created_at DESC LIMIT 1\n) j ON true\nLEFT JOIN LATERAL (\n  SELECT id, downloaded_at FROM library_episodes\n  WHERE shikimori_id = t.mal_id AND episode_number = t.target_episode AND source='autocache'\n  ORDER BY created_at DESC LIMIT 1\n) e ON true\nORDER BY t.created_at DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Autocache cause -> effect (who watched -> what got downloaded)",
      "type": "table"
    }
  ],
