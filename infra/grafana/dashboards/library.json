    {
      "datasource": {
        "type": "postgres",
        "uid": "aenigma-postgres-library"
      },
      "description": "Per-backend storage breakdown from library_episodes: episode-copies stored and total bytes on each backend, plus the combined total (GROUP BY ROLLUP). MinIO = local self-hosted (bucket raw-library); S3 = external s3.firstvds.ru cloud tier. 'Distinct episodes' dedupes dual-presence (the same episode copied to both backends).",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Size"
            },
            "properties": [
              {
