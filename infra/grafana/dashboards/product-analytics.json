        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT count(DISTINCT person_id) AS visitors FROM events_resolved WHERE $__timeFilter(timestamp)"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Sessions",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT count(DISTINCT session_id) AS sessions FROM events_resolved WHERE $__timeFilter(timestamp)"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Anonymous vs identified visitors",
      "type": "piechart",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT CASE WHEN resolved_user_id IS NULL THEN 'anonymous' ELSE 'identified' END AS kind, count(DISTINCT person_id) AS visitors FROM events_resolved WHERE $__timeFilter(timestamp) GROUP BY kind"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Pageviews over time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": 0,
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT toStartOfHour(timestamp) AS time, count() AS pageviews FROM events_resolved WHERE event_type = 'pageview' AND $__timeFilter(timestamp) GROUP BY time ORDER BY time"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Top clicked elements (by label)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 5,
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT if(el_text != '', el_text, concat('⟨', el_tag, ' — no text⟩')) AS label, any(el_selector) AS sample_selector, count() AS clicks FROM events_resolved WHERE event_type = 'click' AND $__timeFilter(timestamp) GROUP BY label ORDER BY clicks DESC LIMIT 25"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Time on page (active seconds, top paths)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 6,
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT path, round(sum(active_ms) / 1000.0, 1) AS active_seconds, count(DISTINCT session_id) AS sessions FROM events_resolved WHERE event_type = 'heartbeat' AND $__timeFilter(timestamp) GROUP BY path ORDER BY active_seconds DESC LIMIT 25"
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aenigma-clickhouse"
      },
      "title": "Most active users (anonymous included)",
      "description": "One row per unique person_id (identified user UUID if ever stitched, else the anonymous id). Ranked by total events in range. 'nickname' resolves the user_id to users.username via the ClickHouse postgresql() table function (anonymous persons show 'anon:<id-prefix>', deleted users show '(deleted user)'). 'kind' = identified once a user_id was ever resolved for that person, else anonymous.",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "active_seconds" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "last_seen" },
            "properties": [{ "id": "unit", "value": "dateTimeAsIso" }]
          },
          {
            "matcher": { "id": "byName", "options": "events" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "text", "value": null }, { "color": "blue", "value": 50 }, { "color": "purple", "value": 500 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "kind" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "anonymous": { "color": "text", "index": 0 } } },
                { "type": "value", "options": { "identified": { "color": "green", "index": 1 } } }
              ] }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "events", "desc": true }]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aenigma-clickhouse"
          },
          "rawQuery": true,
          "format": "table",
          "queryType": "sql",
          "refId": "A",
          "rawSql": "SELECT if(a.kind = 'identified', coalesce(u.username, '(deleted user)'), concat('anon:', substring(a.person_id, 1, 8))) AS nickname, a.person_id AS person_id, a.kind AS kind, a.events AS events, a.pageviews AS pageviews, a.clicks AS clicks, a.sessions AS sessions, a.active_seconds AS active_seconds, a.last_seen AS last_seen FROM (SELECT person_id, if(max(resolved_user_id) IS NULL, 'anonymous', 'identified') AS kind, count() AS events, countIf(event_type = 'pageview') AS pageviews, countIf(event_type = 'click') AS clicks, count(DISTINCT session_id) AS sessions, round(sumIf(active_ms, event_type = 'heartbeat') / 1000.0, 1) AS active_seconds, max(timestamp) AS last_seen FROM events_resolved WHERE $__timeFilter(timestamp) AND person_id != '' GROUP BY person_id) AS a LEFT JOIN (SELECT toString(id) AS id, username FROM postgresql('postgres:5432', 'animeenigma', 'users', 'postgres', 'postgres')) AS u ON a.person_id = u.id ORDER BY a.events DESC LIMIT 50"
        }
      ]
    },
