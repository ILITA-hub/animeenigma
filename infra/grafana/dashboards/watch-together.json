      "pluginVersion": "10.3.3",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (severity) (rate(wt_drift_corrections_total[5m]))",
          "format": "time_series",
